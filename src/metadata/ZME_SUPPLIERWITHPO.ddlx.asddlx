@Metadata.layer: #CUSTOMER
annotate view ZC_SupplierWithPO with
{

// ─── Header Info ──────────────────────────────────────────────────────────────
  @UI.headerInfo: {
    typeName:       'Pedido de Compra',
    typeNamePlural: 'Pedidos de Compra',
    title:       { type: #STANDARD, value: 'PurchaseOrder' },
    description: { type: #STANDARD, value: 'SupplierName'  }
  }

// ─── Data Points (header do Object Page) ─────────────────────────────────────

  @UI.dataPoint #DPStatus: {
    title:       'Status',
    criticality: 'POStatusCriticality'
  }
  @UI.dataPoint #DPIsCustomer: {
    title:       'É Também Cliente?',
    criticality: 'IsAlsoCustomerCritclty'
  }
  @UI.dataPoint #DPCompanyCode: {
    title: 'Empresa'
  }
  @UI.dataPoint #DPPurchOrg: {
    title: 'Org. de Compras'
  }
  @UI.dataPoint #DPPODate: {
    title: 'Data do Pedido'
  }
  @UI.dataPoint #DPCurrency: {
    title: 'Moeda'
  }

// ─── Facets ───────────────────────────────────────────────────────────────────

  @UI.facet: [
    // ── Header data points ──────────────────────────────────────────
    { id: 'HFStatus',     purpose: #HEADER, type: #DATAPOINT_REFERENCE,
      targetQualifier: 'DPStatus',      position: 10 },
    { id: 'HFIsCustomer', purpose: #HEADER, type: #DATAPOINT_REFERENCE,
      targetQualifier: 'DPIsCustomer',  position: 20 },
    { id: 'HFCompCode',   purpose: #HEADER, type: #DATAPOINT_REFERENCE,
      targetQualifier: 'DPCompanyCode', position: 30 },
    { id: 'HFPurchOrg',   purpose: #HEADER, type: #DATAPOINT_REFERENCE,
      targetQualifier: 'DPPurchOrg',    position: 40 },
    { id: 'HFPODate',     purpose: #HEADER, type: #DATAPOINT_REFERENCE,
      targetQualifier: 'DPPODate',      position: 50 },
    { id: 'HFCurrency',   purpose: #HEADER, type: #DATAPOINT_REFERENCE,
      targetQualifier: 'DPCurrency',    position: 60 },

    // ── Facet 1: Dados do Pedido ─────────────────────────────────────
    { id: 'FacetPO',      type: #COLLECTION,
      label: 'Dados do Pedido',         position: 10 },
    { id: 'FGPOMain',     type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGPOMain',      parentId: 'FacetPO',
      label: 'Informações Gerais',      position: 10 },
    { id: 'FGPOStatus',   type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGPOStatus',    parentId: 'FacetPO',
      label: 'Status e Liberação',      position: 20 },
    { id: 'FGPOInco',     type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGPOInco',      parentId: 'FacetPO',
      label: 'Incoterms',               position: 30 },
    { id: 'FGPOExch',     type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGPOExch',      parentId: 'FacetPO',
      label: 'Câmbio e Validade',       position: 40 },
    { id: 'FGPOCompl',    type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGPOCompl',     parentId: 'FacetPO',
      label: 'Conformidade',            position: 50 },

    // ── Facet 2: Referências e Pagamento ─────────────────────────────
    { id: 'FacetRef',     type: #COLLECTION,
      label: 'Referências e Pagamento', position: 20 },
    { id: 'FGRefMain',    type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGRefMain',     parentId: 'FacetRef',
      label: 'Referências',             position: 10 },
    { id: 'FGRefPay',     type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGRefPay',      parentId: 'FacetRef',
      label: 'Descontos e Pagamento',   position: 20 },
    { id: 'FGRefDown',    type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGRefDown',     parentId: 'FacetRef',
      label: 'Adiantamento',            position: 30 },
    { id: 'FGRefFiscal',  type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGRefFiscal',   parentId: 'FacetRef',
      label: 'Fiscal',                  position: 40 },

    // ── Facet 3: Dados do Fornecedor ──────────────────────────────────
    { id: 'FacetSupp',    type: #COLLECTION,
      label: 'Dados do Fornecedor',     position: 30 },
    { id: 'FGSuppId',     type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGSuppId',      parentId: 'FacetSupp',
      label: 'Identificação',           position: 10 },
    { id: 'FGSuppAddr',   type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGSuppAddr',    parentId: 'FacetSupp',
      label: 'Endereço',                position: 20 },
    { id: 'FGSuppContact',type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGSuppContact', parentId: 'FacetSupp',
      label: 'Contato',                 position: 30 },
    { id: 'FGSuppFiscal', type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGSuppFiscal',  parentId: 'FacetSupp',
      label: 'Fiscal',                  position: 40 },
    { id: 'FGSuppBlock',  type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGSuppBlock',   parentId: 'FacetSupp',
      label: 'Bloqueios',               position: 50 },
    { id: 'FGSuppLogist', type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGSuppLogist',  parentId: 'FacetSupp',
      label: 'Logística',               position: 60 },
    { id: 'FGSuppConfig', type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGSuppConfig',  parentId: 'FacetSupp',
      label: 'Configurações',           position: 70 },

    // ── Facet 4: Dados do Cliente ──────────────────────────────────────
    { id: 'FacetCust',    type: #COLLECTION,
      label: 'Dados do Cliente',        position: 40 },
    { id: 'FGCustId',     type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGCustId',      parentId: 'FacetCust',
      label: 'Identificação',           position: 10 },
    { id: 'FGCustAddr',   type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGCustAddr',    parentId: 'FacetCust',
      label: 'Endereço',                position: 20 },
    { id: 'FGCustBlock',  type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGCustBlock',   parentId: 'FacetCust',
      label: 'Bloqueios',               position: 30 },
    { id: 'FGCustSales',  type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGCustSales',   parentId: 'FacetCust',
      label: 'Vendas',                  position: 40 },
    { id: 'FGCustAttr',   type: #FIELDGROUP_REFERENCE,
      targetQualifier: 'FGCustAttr',    parentId: 'FacetCust',
      label: 'Atributos Livres',        position: 50 }
  ]

// ─── Line Items (List Report) ─────────────────────────────────────────────────

  @UI.lineItem: [{ position: 10, label: 'Fornecedor' }]
  Supplier;

  @UI.lineItem: [{ position: 20, label: 'Nome do Fornecedor' }]
  SupplierName;

  @UI.lineItem: [{ position: 30, label: 'É Também Cliente?',
                   criticality: 'IsAlsoCustomerCritclty',
                   criticalityRepresentation: #WITH_ICON }]
  IsAlsoCustomer;

  @UI.lineItem: [{ position: 40, label: 'Pedido de Compra' }]
  PurchaseOrder;

  @UI.lineItem: [{ position: 50, label: 'Data do Pedido' }]
  PurchaseOrderDate;

  @UI.lineItem: [{ position: 60, label: 'Tipo' }]
  PurchaseOrderType;

  @UI.lineItem: [{ position: 70, label: 'Empresa' }]
  CompanyCode;

  @UI.lineItem: [{ position: 80, label: 'Org. de Compras' }]
  PurchasingOrganization;

  @UI.lineItem: [{ position: 90, label: 'Grupo de Compras',
                   importance: #LOW }]
  PurchasingGroup;

  @UI.lineItem: [{ position: 100, label: 'Moeda' }]
  DocumentCurrency;

  @UI.lineItem: [{ position: 110, label: 'Status',
                   criticality: 'POStatusCriticality',
                   criticalityRepresentation: #WITH_ICON }]
  PurchasingProcessingStatus;

  @UI.lineItem: [{ position: 120, label: 'Completude',
                   criticality: 'POStatusCriticality',
                   criticalityRepresentation: #WITHOUT_ICON }]
  PurchasingCompletenessStatus;

  @UI.lineItem: [{ position: 130, label: 'Data de Criação',
                   importance: #LOW }]
  CreationDate;

  @UI.lineItem: [{ position: 140, label: 'Criado Por',
                   importance: #LOW }]
  CreatedByUser;

// ─── Selection Fields (filtros) ───────────────────────────────────────────────

  @UI.selectionField: [{ position: 10 }]
  CompanyCode;

  @UI.selectionField: [{ position: 20 }]
  PurchaseOrderDate;

  @UI.selectionField: [{ position: 30 }]
  PurchasingOrganization;

  @UI.selectionField: [{ position: 40 }]
  Supplier;

  @UI.selectionField: [{ position: 50 }]
  PurchaseOrderType;

// ─── Data Points (campos anotados) ───────────────────────────────────────────

  @UI.dataPoint #DPStatus:
  PurchasingProcessingStatus;

  @UI.dataPoint #DPIsCustomer:
  IsAlsoCustomer;

  @UI.dataPoint #DPCompanyCode:
  CompanyCode;

  @UI.dataPoint #DPPurchOrg:
  PurchasingOrganization;

  @UI.dataPoint #DPPODate:
  PurchaseOrderDate;

  @UI.dataPoint #DPCurrency:
  DocumentCurrency;

// ─── Field Groups — Facet 1: Dados do Pedido ─────────────────────────────────

  @UI.fieldGroup: [{ qualifier: 'FGPOMain', position: 10,  label: 'Tipo' }]
  PurchaseOrderType;
  @UI.fieldGroup: [{ qualifier: 'FGPOMain', position: 20,  label: 'Subtipo' }]
