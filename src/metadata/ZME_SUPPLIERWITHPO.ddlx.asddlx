  @UI.fieldGroup: [{ qualifier: 'FGPOMain', position: 30,  label: 'Empresa' }]
  CompanyCode;
  @UI.fieldGroup: [{ qualifier: 'FGPOMain', position: 40,  label: 'Org. de Compras' }]
  PurchasingOrganization;
  @UI.fieldGroup: [{ qualifier: 'FGPOMain', position: 50,  label: 'Grupo de Compras' }]
  PurchasingGroup;
  @UI.fieldGroup: [{ qualifier: 'FGPOMain', position: 60,  label: 'Fornecedor' }]
  Supplier;
  @UI.fieldGroup: [{ qualifier: 'FGPOMain', position: 70,  label: 'Data do Pedido' }]
  PurchaseOrderDate;
  @UI.fieldGroup: [{ qualifier: 'FGPOMain', position: 80,  label: 'Data de Criação' }]
  CreationDate;
  @UI.fieldGroup: [{ qualifier: 'FGPOMain', position: 90,  label: 'Criado Por' }]
